<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Mobile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('Partials/Navbar') %>

    <div class="container mt-4">
        <h1 class="text-center mb-4">Edit Mobile</h1>
        
        <div class="row justify-content-center">
            <div class="col-md-6">
                <form action="/update/<%= data._id %>" method="POST">
                    <input type="hidden" name="_method" value="PUT">
                    <div class="mb-3">
                        <label for="name" class="form-label">Mobile Name</label>
                        <input type="text" class="form-control" id="name" name="name" value="<%= data.name %>" required>
                    </div>
                    <div class="mb-3">
                        <label for="brand" class="form-label">Brand</label>
                        <input type="text" class="form-control" id="brand" name="brand" value="<%= data.brand %>" required>
                    </div>
                    <div class="mb-3">
                        <label for="prise" class="form-label">Price</label>
                        <input type="number" class="form-control" id="prise" name="prise" value="<%= data.prise %>" required>
                    </div>
                    <button type="submit" class="btn btn-primary">Update Mobile</button>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>