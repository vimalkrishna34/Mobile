<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mobile Collection</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('Partials/Navbar') %>

    <div class="container mt-4">
        <h1 class="text-center mb-4">Mobile Collection</h1>
        
        <div class="text-end mb-3">
            <a href="/add" class="btn btn-primary">Add New Mobile</a>
        </div>

        <div class="row">
            <% data.forEach(mobile => { %>
                <div class="col-md-4 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title"><%= mobile.name %></h5>
                            <h6 class="card-subtitle mb-2 text-muted"><%= mobile.brand %></h6>
                            <p class="card-text">Price: $<%= mobile.prise %></p>
                            <a href="/<%= mobile._id %>" class="btn btn-info btn-sm">Details</a>
                            <a href="/edit/<%= mobile._id %>" class="btn btn-warning btn-sm">Edit</a>
                            <form action="/delete/<%= mobile._id %>" method="POST" style="display: inline;">
                                <input type="hidden" name="_method" value="DELETE">
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>