<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mobile Phones</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f8f9fa;
            color: #333;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: #111;
            padding: 15px 20px;
            color: white;
        }
        .navbar .logo {
            font-size: 24px;
            font-weight: bold;
        }
        .navbar nav a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
            font-size: 18px;
        }
        .sign-in {
            background-color: #f1c40f;
            padding: 10px 20px;
            border-radius: 5px;
            color: black;
            font-weight: bold;
            text-decoration: none;
        }

        .product-section {
            text-align: center;
            padding: 30px;
        }

        .product-list {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 20px;
            margin-top: 20px;
        }

        .product-card {
            background-color: white;
            padding: 15px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            flex: 1 1 250px;
            max-width: 300px;
            position: relative;
        }

        .product-card img {
            width: 100%;
            max-height: 200px;
            object-fit: cover;
            border-radius: 5px;
        }

        .product-card h3 {
            font-size: 18px;
            margin-top: 10px;
        }

        .discount {
            text-decoration: line-through;
            color: red;
            font-size: 14px;
        }

        .add-to-cart {
            background-color: #f1c40f;
            padding: 10px 15px;
            border: none;
            cursor: pointer;
            border-radius: 5px;
            font-size: 14px;
            font-weight: bold;
            margin-top: 10px;
            width: 100%;
        }

        .action-buttons {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .edit-btn {
            background-color: #3498db;
            color: white;
            padding: 8px 12px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            flex: 1;
        }

        .delete-btn {
            background-color: #e74c3c;
            color: white;
            padding: 8px 12px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            flex: 1;
        }

        footer {
            text-align: center;
            padding: 15px;
            background-color: #111;
            color: white;
            margin-top: 30px;
        }

        /* Modal styles */
        .modal {
            display: none;
            position: fixed;
            z-index: 1;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0,0,0,0.4);
        }

        .modal-content {
            background-color: #fefefe;
            margin: 15% auto;
            padding: 20px;
            border: 1px solid #888;
            width: 80%;
            max-width: 500px;
            border-radius: 10px;
        }

        .close {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }

        .close:hover {
            color: black;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
        }

        .form-group input {
            width: 100%;
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 4px;
            box-sizing: border-box;
        }

        .save-btn {
            background-color: #2ecc71;
            color: white;
            padding: 10px 15px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
        }
    </style>
</head>
<body>
    <header>
        <div class="navbar">
            <h1 class="logo">MOBILE STORE</h1>
            <nav>
                <a href="/">Home</a>
                <a href="/wishlist">Wishlist</a>
                <a href="/results">Deals</a>
                <a href="#">Contact Us</a>
            </nav>
            <a href="/login" class="sign-in">Sign In</a>
        </div>
    </header>

    <main>
        <section class="product-section">
            <h2>Flagship Phones</h2>
            <div class="product-list">
                <% let flagships = [
                    { id: 1, name: 'iPhone 15 Pro Max', price: 1199, originalPrice: 1399, image: 'https://i.pinimg.com/736x/cb/2a/d0/cb2ad0bbc24149758f88797d22b54ab7.jpg' },
                    { id: 2, name: 'Samsung Galaxy S24 Ultra', price: 1299, originalPrice: 1499, image: 'https://i.pinimg.com/736x/5b/d8/93/5bd893c5ec4277bc4cff54fbb3e79afb.jpg' },
                    { id: 3, name: 'Google Pixel 8 Pro', price: 999, originalPrice: 1199, image: 'https://i.pinimg.com/736x/35/dc/2a/35dc2a7473c7fcdf24799b2f187dbf45.jpg' },
                    { id: 4, name: 'OnePlus 12', price: 899, originalPrice: 1099, image: 'https://i.pinimg.com/736x/09/26/d2/0926d2846a283d22da8066fc737567d3.jpg' }
                ]; %>

                <% flagships.forEach(phone => { %>
                    <div class="product-card" data-id="<%= phone.id %>">
                        <img src="<%= phone.image %>" alt="<%= phone.name %>">
                        <h3><%= phone.name %></h3>
                        <p>$<%= phone.price %> <span class="discount">$<%= phone.originalPrice %></span></p>
                        <button class="add-to-cart">Buy Now</button>
                        <div class="action-buttons">
                            <button class="edit-btn" onclick="openEditModal(<%= phone.id %>)">Edit</button>
                            <button class="delete-btn" onclick="deleteProduct(<%= phone.id %>)">Delete</button>
                        </div>
                    </div>
                <% }); %>
            </div>
        </section>

        <section class="product-section">
            <h2>Mid-Range Phones</h2>
            <div class="product-list">
                <% let midrange = [
                    { id: 5, name: 'Samsung Galaxy A54', price: 449, originalPrice: 499, image: 'https://i.pinimg.com/736x/3b/e2/bc/3be2bcd2797541ad205a8dc7dfc4a97d.jpg' },
                    { id: 6, name: 'Google Pixel 7a', price: 499, originalPrice: 549, image: 'https://i.pinimg.com/736x/93/9e/17/939e17b0720d07b5ffce2d206347d193.jpg' },
                    { id: 7, name: 'iPhone SE (2024)', price: 429, originalPrice: 479, image: 'https://i.pinimg.com/736x/52/ca/61/52ca6192f83789502436fa2f81fc6ca9.jpg' },
                    { id: 8, name: 'Xiaomi Redmi Note 13 Pro', price: 399, originalPrice: 449, image: 'https://i.pinimg.com/736x/0c/fc/35/0cfc354f53b3a9ee1b6c24e0ad954ab2.jpg' }
                ]; %>

                <% midrange.forEach(phone => { %>
                    <div class="product-card" data-id="<%= phone.id %>">
                        <img src="<%= phone.image %>" alt="<%= phone.name %>">
                        <h3><%= phone.name %></h3>
                        <p>$<%= phone.price %> <span class="discount">$<%= phone.originalPrice %></span></p>
                        <button class="add-to-cart">Buy Now</button>
                        <div class="action-buttons">
                            <button class="edit-btn" onclick="openEditModal(<%= phone.id %>)">Edit</button>
                            <button class="delete-btn" onclick="deleteProduct(<%= phone.id %>)">Delete</button>
                        </div>
                    </div>
                <% }); %>
            </div>
        </section>

        <section class="product-section">
            <h2>Budget Phones</h2>
            <div class="product-list">
                <% let budget = [
                    { id: 9, name: 'Moto G Power (2025)', price: 199, originalPrice: 249, image: 'https://i.pinimg.com/736x/34/28/e1/3428e14a292a8dc44f4b5ed64af02f51.jpg' },
                    { id: 10, name: 'Samsung Galaxy A14', price: 179, originalPrice: 229, image: 'https://i.pinimg.com/474x/b4/76/39/b476390fbefb77b757e6824a63619fc5.jpg' },
                    { id: 11, name: 'Nokia G400', price: 159, originalPrice: 199, image: 'https://i.pinimg.com/736x/0f/b8/ef/0fb8ef3926c251efb081e606a9bf0c8f.jpg' },
                    { id: 12, name: 'TCL 40 XE', price: 129, originalPrice: 169, image: 'https://i.pinimg.com/736x/08/a2/8d/08a28d366d253c90bd4dda1bac523afa.jpg' }
                ]; %>

                <% budget.forEach(phone => { %>
                    <div class="product-card" data-id="<%= phone.id %>">
                        <img src="<%= phone.image %>" alt="<%= phone.name %>">
                        <h3><%= phone.name %></h3>
                        <p>$<%= phone.price %> <span class="discount">$<%= phone.originalPrice %></span></p>
                        <button class="add-to-cart">Buy Now</button>
                        <div class="action-buttons">
                            <button class="edit-btn" onclick="openEditModal(<%= phone.id %>)">Edit</button>
                            <button class="delete-btn" onclick="deleteProduct(<%= phone.id %>)">Delete</button>
                        </div>
                    </div>
                <% }); %>
            </div>
        </section>
    </main>

    <!-- Edit Product Modal -->
    <div id="editModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeEditModal()">&times;</span>
            <h2>Edit Product</h2>
            <form id="editForm">
                <input type="hidden" id="editProductId">
                <div class="form-group">
                    <label for="editName">Product Name</label>
                    <input type="text" id="editName" required>
                </div>
                <div class="form-group">
                    <label for="editPrice">Current Price</label>
                    <input type="number" id="editPrice" required>
                </div>
                <div class="form-group">
                    <label for="editOriginalPrice">Original Price</label>
                    <input type="number" id="editOriginalPrice" required>
                </div>
                <div class="form-group">
                    <label for="editImage">Image URL</label>
                    <input type="url" id="editImage" required>
                </div>
                <button type="button" class="save-btn" onclick="saveProductChanges()">Save Changes</button>
            </form>
        </div>
    </div>

    <footer>
        <p>&copy; 2025 Mobile Store. All rights reserved.</p>
    </footer>

    <script>
        // Function to open edit modal with product data
        function openEditModal(productId) {
            // In a real application, you would fetch the product data from your database/API
            // Here we're simulating it by finding the product in our arrays
            
            let product = null;
            
            // Search in flagships
            <% flagships.forEach(phone => { %>
                if (<%= phone.id %> === productId) {
                    product = {
                        id: <%= phone.id %>,
                        name: '<%= phone.name %>',
                        price: <%= phone.price %>,
                        originalPrice: <%= phone.originalPrice %>,
                        image: '<%= phone.image %>'
                    };
                }
            <% }); %>
            
            // Search in midrange
            <% midrange.forEach(phone => { %>
                if (<%= phone.id %> === productId) {
                    product = {
                        id: <%= phone.id %>,
                        name: '<%= phone.name %>',
                        price: <%= phone.price %>,
                        originalPrice: <%= phone.originalPrice %>,
                        image: '<%= phone.image %>'
                    };
                }
            <% }); %>
            
            // Search in budget
            <% budget.forEach(phone => { %>
                if (<%= phone.id %> === productId) {
                    product = {
                        id: <%= phone.id %>,
                        name: '<%= phone.name %>',
                        price: <%= phone.price %>,
                        originalPrice: <%= phone.originalPrice %>,
                        image: '<%= phone.image %>'
                    };
                }
            <% }); %>
            
            if (product) {
                document.getElementById('editProductId').value = product.id;
                document.getElementById('editName').value = product.name;
                document.getElementById('editPrice').value = product.price;
                document.getElementById('editOriginalPrice').value = product.originalPrice;
                document.getElementById('editImage').value = product.image;
                
                document.getElementById('editModal').style.display = 'block';
            }
        }
        
        // Function to close edit modal
        function closeEditModal() {
            document.getElementById('editModal').style.display = 'none';
        }
        
        // Function to save product changes
        function saveProductChanges() {
            const productId = document.getElementById('editProductId').value;
            const name = document.getElementById('editName').value;
            const price = document.getElementById('editPrice').value;
            const originalPrice = document.getElementById('editOriginalPrice').value;
            const image = document.getElementById('editImage').value;
            
            // In a real application, you would send this data to your server
            // Here we're just updating the UI directly for demonstration
            
            const productCard = document.querySelector(`.product-card[data-id="${productId}"]`);
            if (productCard) {
                productCard.querySelector('h3').textContent = name;
                productCard.querySelector('p').innerHTML = `$${price} <span class="discount">$${originalPrice}</span>`;
                productCard.querySelector('img').src = image;
                productCard.querySelector('img').alt = name;
            }
            
            closeEditModal();
            
            alert('Product updated successfully!');
        }
        
        // Function to delete a product
        function deleteProduct(productId) {
            if (confirm('Are you sure you want to delete this product?')) {
                // In a real application, you would send a delete request to your server
                // Here we're just removing the element from the DOM for demonstration
                
                const productCard = document.querySelector(`.product-card[data-id="${productId}"]`);
                if (productCard) {
                    productCard.remove();
                }
                
                alert('Product deleted successfully!');
            }
        }
        
        // Close modal when clicking outside of it
        window.onclick = function(event) {
            const modal = document.getElementById('editModal');
            if (event.target == modal) {
                closeEditModal();
            }
        }
    </script>
</body>
</html>